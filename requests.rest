### Variables
@url = http://localhost:3000/api

@charId = 69cf537bb1c940f8c9d1f7d5
@issueId = 69b1eaf683160834968d6416
@placeId = [PASTE_ID_HERE]
@arcId = 69c725385af6ec0e8ee6ef27


###############################################################################
### PLACES ROUTES
###############################################################################

### 1. GET all places
GET {{url}}/places

### 2. GET a specific place by ID
GET {{url}}/places/{{placeId}}

### 3. POST a new place (Requires Login)
### update schema 
POST {{url}}/places
Content-Type: application/json

{
    "name": "The Obsidian Spire",
    "description": "A mysterious tower located in the heart of the Wastelands.",
    "dangerLevel": "Extreme",
    "associatedHeroes": ["Iron Warden"]
}

### 4. PUT (Update) a place by ID
PUT {{url}}/places/{{placeId}}
Content-Type: application/json

{
    "name": "The Obsidian Spire (Ruins)",
    "description": "The remains of the spire after the Great Battle.",
    "dangerLevel": "Low"
}

### 5. DELETE a place by ID (Requires Login)
DELETE {{url}}/places/{{placeId}}

###############################################################################
### STORY ARCS ROUTES
###############################################################################

### 1. GET all story arcs
GET {{url}}/story-arc

### 2. GET a specific story arc by ID
GET {{url}}/story-arc/{{arcId}}

### 3. POST a new story arc (Requires Login)
POST {{url}}/story-arc
Content-Type: application/json

{
    "title": "The Library of Ash",
    "description": "An ancient library hidden beneath the city holds secrets that could rewrite history.",
    "mainCharacters": ["Shadow Finch", "Iron Warden"],
    "startIssue": 1,
    "endIssue": 12,
    "status": "Ongoing"  
}

### 4. PUT (Update) a story arc by ID
PUT {{url}}/story-arc/{{arcId}}
Content-Type: application/json

{
    "title": "The Fall of the Night-Watch",
    "description": "The final chapter in the Night-Watch saga.",
    "status": "Completed"
   
}

### 5. DELETE a story arc by ID (Requires Login)
DELETE {{url}}/story-arc/{{arcId}}

###############################################################################
