###############################################################################
### ISSUES ROUTES
###############################################################################

### 1. GET all issues
GET {{url}}/issues

### 2. GET a single issue by ID
### (Paste a valid Mongo ID from your 'GET all' response)
GET {{url}}/issues/{{issueId}}

### 3. POST a new issue (Requires Login)
### This must match the schema in src/validation/issueValidation.js
POST {{url}}/issues
Content-Type: application/json

{
    "title": "The Silent Vigil",
    "issueNumber": 2,
    "releaseDate": "2026-04-15",
    "summary": "The Iron Warden joins forces with Shadow Finch to investigate the Spire.",
    "charactersFeatured": ["Shadow Finch", "Iron Warden"],
    "place": "The Obsidian Spire",
    "storyArc": "The Rise of the Night-Watch",
    "pageCount": 32
}

### 4. PUT (Update) an existing issue
PUT {{url}}/issues/{{issueId}}
Content-Type: application/json

{
    "title": "The Silent Vigil: Extended Edition",
    "pageCount": 40,
    "summary": "An expanded look at the battle for the Spire."
}

### 5. DELETE an issue by ID (Requires Login)
DELETE {{url}}/issues/{{issueId}}

